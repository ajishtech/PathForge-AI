# Database (Supabase PostgreSQL)
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Auth.js - generate with: openssl rand -base64 32
AUTH_SECRET="pathforge-dev-secret-change-in-production"
AUTH_URL="http://localhost:3000"

# OAuth (optional - enable Google/GitHub login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# OpenAI (optional - enables enhanced AI features)
OPENAI_API_KEY=""
